# =============================================================================
# Twitch-Discord Bot Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# Get Discord Bot Token: https://discord.com/developers/applications
# Get Twitch API Credentials: https://dev.twitch.tv/console/apps

# =============================================================================
# Discord Bot Configuration
# =============================================================================
# Create a Discord application at https://discord.com/developers/applications
# Go to "Bot" section and copy the token
DISCORD_TOKEN=your_discord_bot_token_here

# Copy the Application ID from the "General Information" section
DISCORD_CLIENT_ID=123456789012345678

# =============================================================================
# Twitch API Configuration
# =============================================================================
# Create a Twitch application at https://dev.twitch.tv/console/apps
# Copy the Client ID and generate a Client Secret
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_CLIENT_SECRET=your_twitch_client_secret_here

# =============================================================================
# Webhook Configuration
# =============================================================================
# Generate a random secret for webhook security (64 characters recommended)
# You can use: openssl rand -hex 32
WEBHOOK_SECRET=your_random_webhook_secret_64_characters_long_for_security_here

# Port for the webhook server (default: 8081)
WEBHOOK_PORT=8081

# Public URL where Twitch can reach your webhook
# Replace with your actual domain/IP and port
WEBHOOK_URL=https://your-domain.com/webhook

# =============================================================================
# Database Configuration
# =============================================================================
# Path to SQLite database file (will be created automatically)
DATABASE_PATH=./data/bot.db

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# =============================================================================
# Kick API Configuration (optional – enables instant webhook notifications)
# =============================================================================
# Create a Kick application at https://kick.com/settings/developer
# Without these, Kick notifications use polling (2-min delay)
KICK_CLIENT_ID=your_kick_client_id_here
KICK_CLIENT_SECRET=your_kick_client_secret_here

# OAuth redirect URI for Kick user authorization (for instant webhook notifications)
# If not set, derived automatically from WEBHOOK_URL (e.g. https://your-domain.com/kick-auth/callback)
# Must match the redirect URI registered in your Kick app settings
# KICK_REDIRECT_URI=https://your-domain.com/kick-auth/callback

# Cooldown between Kick notifications for the same streamer (in seconds)
KICK_NOTIFICATION_COOLDOWN_SECONDS=300

# =============================================================================
# Anti-spam Configuration
# =============================================================================
# Cooldown between notifications for the same streamer (in seconds)
NOTIFICATION_COOLDOWN_SECONDS=30